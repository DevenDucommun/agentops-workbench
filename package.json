{
  "name": "agentops-workbench",
  "version": "1.10.0",
  "private": true,
  "type": "module",
  "bin": {
    "agentops": "./bin/agentops"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "fixtures/",
    "scripts/generate-demo-artifacts.ts",
    "docs/INSTALLATION.md",
    "docs/CLI.md",
    "docs/COMPATIBILITY.md",
    "docs/CONFIGURATION.md",
    "docs/DASHBOARD.md",
    "docs/MCP.md",
    "docs/QUALITY_GATES.md",
    "docs/demo/",
    "docs/REPO_REPORT.md",
    "docs/ROADMAP_POST_1_0.md",
    "docs/CAPTURE_GUIDE.md",
    "docs/EXPORT.md",
    "docs/HOOK_ENVELOPE.md",
    "docs/STANDARDS_MAPPING.md",
    "docs/ADAPTER_STRATEGY.md",
    "docs/EVENT_SCHEMA.md",
    "docs/NATIVE_ADAPTER_RESEARCH.md",
    "agentops.config.example.json",
    "CHANGELOG.md"
  ],
  "scripts": {
    "agentops": "bun ./src/cli.ts",
    "typecheck": "tsc --noEmit",
    "scan:public": "./bin/agentops scan-publication",
    "demo:artifacts": "bun ./scripts/generate-demo-artifacts.ts",
    "smoke:demo-artifacts": "bun ./scripts/generate-demo-artifacts.ts --check",
    "smoke:install": "bun ./scripts/smoke-install.ts",
    "smoke:package": "bun ./scripts/smoke-package.ts",
    "smoke:pack-install": "bun ./scripts/smoke-pack-install.ts",
    "smoke:dashboard": "bun ./scripts/smoke-dashboard.ts",
    "smoke:large-session": "bun ./scripts/smoke-large-session.ts",
    "smoke:release-archive": "bun ./scripts/smoke-release-archive.ts",
    "ci": "bun run typecheck && bun test && bun run smoke:demo-artifacts && bun run scan:public",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
